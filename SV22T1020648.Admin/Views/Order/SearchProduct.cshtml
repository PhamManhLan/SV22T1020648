@model PagedResult<Product>
@{
    Layout = null;
}

@* Kiểm tra nếu không có dữ liệu thì hiện thông báo *@
@if (Model.DataItems == null || Model.DataItems.Count == 0)
{
    <div class="alert alert-warning text-center mt-3">
        <i class="bi bi-search me-2"></i>
        Không tìm thấy mặt hàng nào phù hợp.
    </div>
}
else
{
    @* Có dữ liệu thì vòng lặp vẽ danh sách bình thường *@
    @foreach (var item in Model.DataItems)
    {
        <form method="post" class="border rounded p-2 mb-2 mt-1"
              onsubmit="addCartItem(event,this)">
            <strong>@item.ProductName</strong>
            <input type="hidden" name="productId" value="@item.ProductID" />
            <div class="row mt-2">
                <div class="col-4">
                    @* Bổ sung kiểm tra nếu không có ảnh thì hiển thị ảnh nophoto.png *@
                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                         class="img-fluid border" style="max-height:100px" />
                </div>
                <div class="col-8">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label mb-0">Giá</label>
                            <input class="form-control form-control-sm money-input" name="price" value="@item.Price" />
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-0">SL</label>
                            <input type="number" name="quantity"
                                   min="1"
                                   value="1"
                                   class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                        <i class="bi bi-cart-plus"></i>
                        Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
    }

    @* Chỉ hiện phân trang nếu có nhiều hơn 1 trang *@
    @if (Model.PageCount > 1)
    {
        <ul class="pagination justify-content-between mb-0 mt-2">
            @* Chặn lùi nếu đang ở trang 1 *@
            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:;"
                   onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @* Chặn tiến nếu đang ở trang cuối *@
            <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                <a class="page-link" href="javascript:;"
                   onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    }
}