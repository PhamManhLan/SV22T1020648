@model SV22T1020648.Models.HR.Employee
@{
    ViewBag.Title = "Phân quyền nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i> Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-body">
                <form id="formChangeRole" action="~/Employee/SaveRole" method="post">
                    <input type="hidden" name="employeeId" value="@Model.EmployeeID" />

                    @* Giữ nguyên phần thông tin nhân viên *@
                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3"><i class="bi bi-person me-1"></i> Thông tin nhân viên</legend>
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    @* Cập nhật danh sách quyền theo WebUserRoles *@
                    <fieldset>
                        <legend class="fs-6 text-muted mb-3"><i class="bi bi-shield-lock me-1"></i> Danh sách quyền</legend>
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width:60px;" class="text-center">Chọn</th>
                                        <th>Tên quyền</th>
                                        <th>Mô tả quyền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var currentRoles = Model.RoleNames?.Split(',') ?? new string[] { };
                                    }

                                    @* 1. Quyền Quản trị *@
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="roles"
                                                   value="@WebUserRoles.Administrator"
                                                   @(currentRoles.Contains(WebUserRoles.Administrator) ? "checked" : "") />
                                        </td>
                                        <td class="fw-bold text-danger">Quản trị hệ thống (admin)</td>
                                        <td>Toàn quyền quản lý, cấu hình hệ thống và quản sự nhân viên.</td>
                                    </tr>

                                    @* 2. Quyền Quản lý dữ liệu *@
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="roles"
                                                   value="@WebUserRoles.DataManager"
                                                   @(currentRoles.Contains(WebUserRoles.DataManager) ? "checked" : "") />
                                        </td>
                                        <td class="fw-bold text-primary">Quản lý dữ liệu (datamanager)</td>
                                        <td>Quản lý danh mục hàng hóa, nhà cung cấp, khách hàng và kho.</td>
                                    </tr>

                                    @* 3. Quyền Quản lý bán hàng *@
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="roles"
                                                   value="@WebUserRoles.Sales"
                                                   @(currentRoles.Contains(WebUserRoles.Sales) ? "checked" : "") />
                                        </td>
                                        <td class="fw-bold text-success">Quản lý bán hàng (sales)</td>
                                        <td>Tiếp nhận đơn hàng, lập đơn hàng và quản lý giao nhận.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>