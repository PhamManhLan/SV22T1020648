@model PagedResult<Employee>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px" class="text-center">Ảnh</th>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:160px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">Không tìm thấy nhân viên nào</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="~/images/employees/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                     style="width:50px; height:50px; object-fit:cover"
                                     class="rounded border shadow-sm"
                                     onerror="this.src='/images/employees/nophoto.png'" />
                            </td>
                            <td class="align-middle">@item.FullName</td>
                            <td class="align-middle">@(item.BirthDate.HasValue? item.BirthDate.Value.ToString("dd/MM/yyyy") : "")</td>
                            <td class="align-middle">@item.Phone</td>
                            <td class="align-middle">@item.Email</td>
                            <td class="align-middle">@item.Address</td>
                            <td class="text-center align-middle">
                                @if (item.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã nghỉ việc</span>
                                }
                            </td>
                            <td class="text-center text-nowrap align-middle">
                                <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary" title="Cập nhật">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning ms-2" title="Đổi mật khẩu">
                                    <i class="bi bi-key"></i>
                                </a>
                                <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info" title="Cấp quyền">
                                    <i class="bi bi-shield-check"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsCurrent)
                    {
                        <li class="page-item active"><span class="page-link">@p.Page</span></li>
                    }
                    else if (p.IsEllipsis)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                                @p.Page
                            </a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>