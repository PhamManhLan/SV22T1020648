@model Employee
@{
    ViewBag.Title = "Xóa nhân viên";
    bool canDelete = ViewBag.CanDelete ?? true;
    string photo = string.IsNullOrWhiteSpace(Model.Photo) ? "~/images/employees/nophoto.png" : $"~/images/employees/{Model.Photo}";
}

@section PageToolBar {
    <div class="d-flex">
        @if (canDelete)
        {
            <button type="submit" form="formDelete" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i> Xóa
            </button>
        }
        <a href="~/Employee" class="btn btn-secondary ms-1">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card @(canDelete ? "card-danger" : "card-warning") card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 @(canDelete ? "text-danger" : "text-warning")">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @(canDelete ? "Xác nhận xóa nhân viên" : "Thông báo không thể xóa")
                </h5>
            </div>

            <div class="card-body">
                @if (canDelete)
                {
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa nhân viên này không? Hành động này không thể hoàn tác.
                    </div>
                }
                else
                {
                    <div class="alert alert-danger d-flex align-items-center">
                        <i class="bi bi-slash-circle me-2"></i>
                        Không thể xóa nhân viên này vì đang có dữ liệu liên quan.
                    </div>
                }

                <form id="formDelete" method="post" action="~/Employee/Delete/@Model.EmployeeID">
                    <div class="row">
                        <div class="col-md-3 text-center mb-3">
                            <img src="@Url.Content(photo)" class="img-fluid img-thumbnail" style="max-height:220px;" alt="Ảnh nhân viên" />
                        </div>

                        <div class="col-md-9">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Họ và tên</dt>
                                <dd class="col-sm-8">@Model.FullName</dd>

                                <dt class="col-sm-4">Ngày sinh</dt>
                                <dd class="col-sm-8">
                                    @(Model.BirthDate.HasValue? Model.BirthDate.Value.ToString("dd/MM/yyyy") : "")
                                </dd>

                                <dt class="col-sm-4">Điện thoại</dt>
                                <dd class="col-sm-8">@Model.Phone</dd>

                                <dt class="col-sm-4">Email</dt>
                                <dd class="col-sm-8">@Model.Email</dd>

                                <dt class="col-sm-4">Địa chỉ</dt>
                                <dd class="col-sm-8">@Model.Address</dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsWorking == true)
                                    {
                                        <span class="badge bg-success">Đang làm việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã nghỉ</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>