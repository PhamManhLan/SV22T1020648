@model SV22T1020648.Models.Dashboard.DashboardInfo
@using System.Text.Json

@{
    ViewBag.Title = "Trang chủ";

    var chartLabels = Model.MonthlyRevenues.Select(x => x.MonthLabel).ToList();
    var chartValues = Model.MonthlyRevenues.Select(x => x.Revenue).ToList();
}

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hôm nay</h6>
                        <h3 class="mb-0">@Model.TodayRevenue.ToString("N0") đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng</h6>
                        <h3 class="mb-0">@Model.OrderCount</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@Model.CustomerCount</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">@Model.ProductCount</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ & thống kê -->
<div class="row mt-3">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng
                </h5>
            </div>
            <div class="card-body">
                <div style="height: 320px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top sản phẩm bán chạy
                </h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (Model.TopSellingProducts.Any())
                    {
                        foreach (var item in Model.TopSellingProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                @item.ProductName
                                <span class="badge bg-success">@item.QuantitySold</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted text-center">
                            Chưa có dữ liệu
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng cần xử lý -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th class="text-end">Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PendingOrders.Any())
                        {
                            foreach (var item in Model.PendingOrders)
                            {
                                var badgeClass = "bg-secondary";

                                if (item.StatusDescription.Contains("chờ", StringComparison.OrdinalIgnoreCase))
                                {
                                    badgeClass = "bg-danger";
                                }
                                else if (item.StatusDescription.Contains("giao", StringComparison.OrdinalIgnoreCase))
                                {
                                    badgeClass = "bg-warning text-dark";
                                }
                                else if (item.StatusDescription.Contains("duyệt", StringComparison.OrdinalIgnoreCase))
                                {
                                    badgeClass = "bg-primary";
                                }

                                <tr>
                                    <td>#DH@(item.OrderID.ToString("D5"))</td>
                                    <td>@item.CustomerName</td>
                                    <td>@item.OrderTime.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">@item.TotalAmount.ToString("N0") đ</td>
                                    <td><span class="badge @badgeClass">@item.StatusDescription</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    Không có đơn hàng cần xử lý
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(chartLabels));
        const values = @Html.Raw(JsonSerializer.Serialize(chartValues));

        const ctx = document.getElementById('revenueChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: values,
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                return new Intl.NumberFormat('vi-VN').format(context.raw) + ' đ';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return new Intl.NumberFormat('vi-VN').format(value) + ' đ';
                            }
                        }
                    }
                }
            }
        });
    </script>
}