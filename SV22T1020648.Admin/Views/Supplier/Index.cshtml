@model PaginationSearchInput

@{
    ViewBag.Title = "Quản lý nhà cung cấp";
}

@section PageToolBar {
    <!-- Nút thêm mới -->
    <a href="~/Supplier/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <!-- Form tìm kiếm -->
        <form id="formSearch"
              method="get"
              action="~/Supplier/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <input type="hidden" asp-for="PageSize" />

            <div class="input-group">
                <input type="text" asp-for="SearchValue"
                       class="form-control"
                       placeholder="Tên nhà cung cấp..." autofocus />

                <button class="btn btn-info">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Khu vực hiển thị kết quả -->
<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}