@model Customer
@{
    ViewBag.Title = "Xóa khách hàng";
    bool canDelete = ViewBag.CanDelete ?? true;
}

@section PageToolBar {
    <div class="d-flex">
        @if (canDelete)
        {
            <button type="submit" form="formDelete" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i> Xóa
            </button>
        }
        <a href="~/Customer" class="btn btn-secondary ms-1">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card @(canDelete ? "card-danger" : "card-warning") card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 @(canDelete ? "text-danger" : "text-warning")">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @(canDelete ? "Xác nhận xóa khách hàng" : "Thông báo không thể xóa")
                </h5>
            </div>

            <div class="card-body">
                @if (canDelete)
                {
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa khách hàng này không? Hành động này không thể hoàn tác.
                    </div>
                }
                else
                {
                    <div class="alert alert-danger d-flex align-items-center">
                        <i class="bi bi-slash-circle me-2"></i>
                        Không thể xóa khách hàng này vì đang có dữ liệu liên quan.
                    </div>
                }

                <form id="formDelete" method="post" action="~/Customer/Delete/@Model.CustomerID">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Tên khách hàng</dt>
                        <dd class="col-sm-8">@Model.CustomerName</dd>

                        <dt class="col-sm-4">Tên giao dịch</dt>
                        <dd class="col-sm-8">@Model.ContactName</dd>

                        <dt class="col-sm-4">Điện thoại</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Địa chỉ</dt>
                        <dd class="col-sm-8">@Model.Address</dd>

                        <dt class="col-sm-4">Tỉnh/Thành</dt>
                        <dd class="col-sm-8">@Model.Province</dd>

                        <dt class="col-sm-4">Trạng thái</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsLocked)
                            {
                                <span class="badge bg-danger">Bị khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                        </dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>