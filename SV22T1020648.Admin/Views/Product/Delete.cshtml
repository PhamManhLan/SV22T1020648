@model Product
@{
    ViewBag.Title = "Xóa mặt hàng";
    bool canDelete = ViewBag.CanDelete ?? true;
}

@section PageToolBar {
    <div class="d-flex">
        @if (canDelete)
        {
            <button type="submit" form="formDelete" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i> Xóa
            </button>
        }
        <a href="~/Product" class="btn btn-secondary ms-1">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card @(canDelete ? "card-danger" : "card-warning") card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 @(canDelete ? "text-danger" : "text-warning")">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @(canDelete ? "Xác nhận xóa mặt hàng" : "Thông báo không thể xóa")
                </h5>
            </div>

            <div class="card-body">
                @if (canDelete)
                {
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa mặt hàng này không? Hành động này không thể hoàn tác.
                    </div>
                }
                else
                {
                    <div class="alert alert-danger d-flex align-items-center">
                        <i class="bi bi-slash-circle me-2"></i>
                        Không thể xóa mặt hàng này vì đang có dữ liệu liên quan.
                    </div>
                }

                <form id="formDelete" method="post" action="~/Product/Delete/@Model.ProductID">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Tên mặt hàng</dt>
                        <dd class="col-sm-8">@Model.ProductName</dd>

                        <dt class="col-sm-4">Nhà cung cấp</dt>
                        <dd class="col-sm-8">@Model.SupplierID</dd>

                        <dt class="col-sm-4">Loại hàng</dt>
                        <dd class="col-sm-8">@Model.CategoryID</dd>

                        <dt class="col-sm-4">Đơn vị tính</dt>
                        <dd class="col-sm-8">@Model.Unit</dd>

                        <dt class="col-sm-4">Giá bán</dt>
                        <dd class="col-sm-8">@Model.Price.ToString("N0")</dd>

                        <dt class="col-sm-4">Ảnh đại diện</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.Photo))
                            {
                                <div>
                                    <div class="mb-2">@Model.Photo</div>
                                    <img src="~/images/products/@Model.Photo"
                                         alt="Ảnh mặt hàng"
                                         style="max-height:120px; border:1px solid #ddd; padding:4px;" />
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">Không có ảnh</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Mô tả</dt>
                        <dd class="col-sm-8">@Model.ProductDescription</dd>

                        <dt class="col-sm-4">Trạng thái</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng bán</span>
                            }
                        </dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>