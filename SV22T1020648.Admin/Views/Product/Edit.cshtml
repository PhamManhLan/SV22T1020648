@model Product

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @Html.ValidationMessage("Error", new { @class = "text-danger" })

        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/SaveData">
                    <input type="hidden" asp-for="ProductID" />

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Tên mặt hàng</label>
                            <input type="text" asp-for="ProductName"
                                   class="form-control"
                                   autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Đơn vị tính</label>
                            <input type="text" asp-for="Unit"
                                   class="form-control" />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nhà cung cấp</label>
                            <select class="form-select" asp-for="SupplierID" asp-items="await SelectListHelper.Suppliers()">
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Loại hàng</label>
                            <select class="form-select" asp-for="CategoryID" asp-items="await SelectListHelper.Categories()">
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row align-items-end">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giá bán</label>
                            <input type="number" asp-for="Price"
                                   class="form-control"
                                   min="0"
                                   step="0.01" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" asp-for="IsSelling"
                                       type="checkbox"
                                       id="IsSelling" />
                                <label class="form-check-label" for="IsSelling">
                                    Đang được bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ảnh đại diện</label>
                        <input type="text" asp-for="Photo"
                               class="form-control"
                               placeholder="Nhập tên file ảnh hoặc đường dẫn..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả mặt hàng</label>
                        <textarea class="form-control" asp-for="ProductDescription"
                                  rows="4"></textarea>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>