@model Product
@using SV22T1020648.Models.Catalog

@{
    ViewBag.Title = "Chi tiết mặt hàng";

    var attributes = ViewBag.ListAttributes as List<ProductAttribute>;
    var photos = ViewBag.ListPhotos as List<ProductPhoto>;
}

@section PageToolBar {
    <a asp-controller="Product"
       asp-action="Edit"
       asp-route-id="@Model.ProductID"
       class="btn btn-primary">
        <i class="bi bi-pencil-square"></i>
        Cập nhật
    </a>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<!-- TRẠNG THÁI KINH DOANH -->
@if (Model.IsSelling)
{
    <div class="alert alert-success d-flex align-items-center mb-3">
        <i class="bi bi-check-circle-fill fs-4 me-2"></i>
        <div>
            <strong>Trạng thái:</strong> Mặt hàng đang được kinh doanh
        </div>
    </div>
}
else
{
    <div class="alert alert-warning d-flex align-items-center mb-3">
        <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
        <div>
            <strong>Trạng thái:</strong> Mặt hàng hiện đang ngừng kinh doanh
        </div>
    </div>
}

<!-- THÔNG TIN MẶT HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Thông tin mặt hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã mặt hàng</div>
            <div class="col-md-3">@Model.ProductID</div>

            <div class="col-md-3 fw-bold">Tên mặt hàng</div>
            <div class="col-md-3">@Model.ProductName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã loại hàng</div>
            <div class="col-md-3">
                @(Model.CategoryID.HasValue? Model.CategoryID.ToString() : "Chưa cập nhật")
            </div>

            <div class="col-md-3 fw-bold">Mã nhà cung cấp</div>
            <div class="col-md-3">
                @(Model.SupplierID.HasValue? Model.SupplierID.ToString() : "Chưa cập nhật")
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Đơn vị tính</div>
            <div class="col-md-3">@Model.Unit</div>

            <div class="col-md-3 fw-bold">Giá bán</div>
            <div class="col-md-3 text-danger fw-bold">
                @Model.Price.ToString("N0") đ
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Ảnh đại diện</div>
            <div class="col-md-9">
                @if (!string.IsNullOrWhiteSpace(Model.Photo))
                {
                    <img src="~/images/products/@Model.Photo"
                         class="img-thumbnail"
                         style="max-height:120px" />
                }
                else
                {
                    <span class="text-muted">Chưa có ảnh đại diện</span>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Mô tả mặt hàng</div>
            <div class="col-md-9">
                @(string.IsNullOrWhiteSpace(Model.ProductDescription) ? "Không có mô tả" : Model.ProductDescription)
            </div>
        </div>
    </div>
</div>

<!-- DANH SÁCH THUỘC TÍNH -->
<div class="card card-info card-outline mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            <i class="bi bi-list-ul me-2"></i>
            Danh sách thuộc tính
        </h5>

        <a asp-controller="Product"
           asp-action="EditAttribute"
           asp-route-id="@Model.ProductID"
           asp-route-attributeId="0"
           class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle"></i>
            Bổ sung thuộc tính
        </a>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-info text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên thuộc tính</th>
                    <th>Giá trị thuộc tính</th>
                    <th>Thứ tự hiển thị</th>
                    <th style="width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (attributes != null && attributes.Count > 0)
                {
                    int i = 1;
                    foreach (var item in attributes.OrderBy(x => x.DisplayOrder))
                    {
                        <tr>
                            <td class="text-center">@i</td>
                            <td>@item.AttributeName</td>
                            <td>@item.AttributeValue</td>
                            <td class="text-center">@item.DisplayOrder</td>
                            <td class="text-center">
                                <a asp-controller="Product"
                                   asp-action="EditAttribute"
                                   asp-route-id="@Model.ProductID"
                                   asp-route-attributeId="@item.AttributeID"
                                   class="btn btn-sm btn-primary"
                                   title="Cập nhật thuộc tính">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-controller="Product"
                                   asp-action="DeleteAttribute"
                                   asp-route-id="@Model.ProductID"
                                   asp-route-attributeId="@item.AttributeID"
                                   class="btn btn-sm btn-danger open-modal"
                                   title="Xóa thuộc tính">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            Mặt hàng này chưa có thuộc tính nào
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- DANH SÁCH ẢNH -->
<div class="card card-success card-outline">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            <i class="bi bi-images me-2"></i>
            Danh sách ảnh
        </h5>

        <a asp-controller="Product"
           asp-action="EditPhoto"
           asp-route-id="@Model.ProductID"
           asp-route-photoId="0"
           class="btn btn-sm btn-primary">
            <i class="bi bi-plus-circle"></i>
            Bổ sung ảnh
        </a>
    </div>

    <div class="card-body">
        @if (photos != null && photos.Count > 0)
        {
            <div class="row">
                @foreach (var item in photos.OrderBy(x => x.DisplayOrder))
                {
                    <div class="col-md-3 mb-3">
                        <div class="card h-100 shadow-sm">
                            <img src="~/images/products/@item.Photo"
                                 class="card-img-top"
                                 style="height:220px; object-fit:cover;" />

                            <div class="card-body p-2">
                                <div class="mb-1">
                                    <span class="fw-bold">Mô tả:</span>
                                    <div class="small text-muted">
                                        @(string.IsNullOrWhiteSpace(item.Description) ? "Không có mô tả" : item.Description)
                                    </div>
                                </div>

                                <div class="small">
                                    <span class="fw-bold">Thứ tự hiển thị:</span> @item.DisplayOrder
                                </div>

                                <div class="small mt-1">
                                    <span class="fw-bold">Hiển thị:</span>
                                    @if (item.IsHidden)
                                    {
                                        <span class="text-danger">Đang ẩn</span>
                                    }
                                    else
                                    {
                                        <span class="text-success">Đang hiển thị</span>
                                    }
                                </div>
                            </div>

                            <div class="card-footer text-end bg-white">
                                <a asp-controller="Product"
                                   asp-action="EditPhoto"
                                   asp-route-id="@Model.ProductID"
                                   asp-route-photoId="@item.PhotoID"
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-controller="Product"
                                   asp-action="DeletePhoto"
                                   asp-route-id="@Model.ProductID"
                                   asp-route-photoId="@item.PhotoID"
                                   class="btn btn-sm btn-danger open-modal">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted py-4">
                Mặt hàng này chưa có ảnh nào
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
            padding-top: 8px;
            padding-bottom: 8px;
        }

            .card-body .row:last-child {
                border-bottom: none;
            }
    </style>
}
@section Scripts {
    <script>
        function deleteAttribute(productID, attributeID) {
            fetch(`/Product/DeleteAttribute?id=${productID}&attributeId=${attributeID}`, {
                method: "POST"
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert("Không thể xóa thuộc tính.");
                }
            })
            .catch(error => {
                console.error(error);
                alert("Có lỗi xảy ra khi xóa thuộc tính!");
            });
        }
                function deletePhoto(productID, photoID) {
            fetch(`/Product/DeletePhoto?id=${productID}&photoId=${photoID}`, {
                method: "POST"
            })
            .then(response => response.json())
            .then(data => {
                if (data.code == 0) {
                    alert(data.message);
                    return;
                }

                location.reload();
            })
            .catch(error => {
                console.error(error);
                alert("Có lỗi xảy ra khi xóa ảnh!");
            });
        }
    </script>
}