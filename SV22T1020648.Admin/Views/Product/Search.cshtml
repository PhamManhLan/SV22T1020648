@model PagedResult<Product>
@{
    Layout = null;
}
<table class="table table-bordered table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Tên hàng</th>
            <th>Đơn vị</th>
            <th>Giá</th>
            <th class="text-center">Trạng thái</th>
            <th style="width:160px;" class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.DataItems)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Unit</td>
                <td>@item.Price.ToString("N0") đ</td>
                <td class="text-center">
                    @if (item.IsSelling)
                    {
                        <span class="badge bg-success">Đang bán</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ngừng bán</span>
                    }
                </td>
                <td class="text-center">
                    <div class="btn-group btn-group-sm">
                        <a href="~/Product/Detail/@item.ProductID"
                           class="btn btn-info"
                           title="Xem chi tiết">
                            <i class="bi bi-eye"></i>
                        </a>

                        <a href="~/Product/Edit/@item.ProductID"
                           class="btn btn-primary"
                           title="Cập nhật">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <a href="~/Product/Delete/@item.ProductID"
                           class="btn btn-danger open-modal"
                           title="Xóa">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>