@model ProductAttribute

@{
    ViewBag.Title = Model.AttributeID == 0 ? "Bổ sung thuộc tính" : "Cập nhật thuộc tính";
}

<div class="box box-primary">
    <div class="box-body">
        <form asp-action="SaveAttribute" method="post">
            <input type="hidden" asp-for="AttributeID" />
            <input type="hidden" asp-for="ProductID" />

            <div class="form-group mb-3">
                <label asp-for="AttributeName" class="control-label fw-bold">Tên thuộc tính:</label>
                <input asp-for="AttributeName" class="form-control" autofocus />
                <span asp-validation-for="AttributeName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AttributeValue" class="control-label fw-bold">Giá trị thuộc tính:</label>
                <input asp-for="AttributeValue" class="form-control" />
                <span asp-validation-for="AttributeValue" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DisplayOrder" class="control-label fw-bold">Thứ tự hiển thị:</label>
                <input asp-for="DisplayOrder" class="form-control" type="number" min="0" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy"></i> Lưu dữ liệu
                </button>

                <a asp-action="Detail"
                   asp-route-id="@Model.ProductID"
                   class="btn btn-secondary ms-2">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}