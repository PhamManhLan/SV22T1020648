@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - SV22T1020648 Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #f8f9fa;
        }

        .card {
            border-radius: 15px;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="card shadow border-0">
                    <div class="card-header bg-primary text-white text-center py-3">
                        <h4 class="mb-0">ĐĂNG NHẬP</h4>
                    </div>
                    <div class="card-body p-4">
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success small">
                                <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                            </div>
                        }

                        <form action="~/Account/Login" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label class="form-label fw-bold">Email đăng nhập</label>
                                <input type="text" name="username" class="form-control"
                                       value="@ViewBag.Username" placeholder="Nhập email..." autofocus required />
                            </div>

                            <div class="mb-2">
                                <label class="form-label fw-bold">Mật khẩu</label>
                                <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu..." required />
                            </div>

                            <div class="mb-4 text-end">
                                <a href="~/Account/ForgotPassword" class="text-decoration-none small text-muted">
                                    <i class="bi bi-question-circle"></i> Quên mật khẩu?
                                </a>
                            </div>

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger py-2 small">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                    @Html.ValidationMessage("Error")
                                </div>
                            }

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary fw-bold">Đăng nhập</button>
                            </div>
                        </form>
                    </div>
                    <div class="card-footer text-center bg-white border-top-0 pb-4">
                        <span class="text-muted small">Chưa có tài khoản?</span>
                        <a href="~/Account/SignUp" class="text-decoration-none fw-bold">Đăng ký ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>